enum Role {
  USER
  MANAGER
  ADMIN
}

model UserRole {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(name: "user_role_fk", fields: [user_id], references: [id])
  role    Role
}

model User {
  id        String     @id @default(uuid())
  firstName String?
  lastName  String?
  email     String     @unique
  username  String     @unique
  password  String
  roles     UserRole[] @relation(name: "user_role_fk")
}
